{
  "name": "solana-wallet-balances-api",
  "version": "1.0.0",
  "description": "Solana wallet balances API: fetch SPL & Token-2022 holdings with on-chain RPC amounts, Vybe metadata, and live USD portfolio values for any Solana wallet.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dump:vybe-wallet": "tsx tools/dump-vybe-wallet-token-balance.ts",
    "deploy:vm": "bash scripts/deploy-to-vm.sh",
    "redeploy:vm": "bash scripts/redeploy-vm.sh"
  },
  "keywords": [
    "solana",
    "wallet",
    "balances",
    "vybe",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "1.98.4",
    "axios": "1.7.9",
    "dotenv": "16.4.5",
    "express": "4.21.1"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
