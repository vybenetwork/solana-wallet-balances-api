# Get your API key at https://vybe.fyi/api-pricing
VYBE_DATA_API_KEY=your_api_key_here

# Optional: Vybe API base URL (default: https://api.vybenetwork.xyz)
# VYBE_DATA_API_BASE=https://api.vybenetwork.xyz

# Optional: Server port (default 3001)
# PORT=3001

# Optional: Solana RPC for on-chain balance amounts.
# Priority: SOLANA_RPC_URL → HELIUS_API_KEY → public mainnet.
# HELIUS_API_KEY=your_helius_api_key_here
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: pump.fun price fallback (after Jupiter) and HTTP proxy for outbound calls.
# PUMPFUN_AUTH_TOKEN=your_jwt_if_logged_in
# PUMPFUN_HEADERS_PATH=/path/to/headers.json
# PROXY_HOST=geo.iproyal.com:12321
# PROXY_AUTH=user:pass_country-us
# HTTP_PROXY_POOL_SIZE=10
# HTTP_PROXY_WARMUP=true
